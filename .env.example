# Copy to .env and fill from Supabase Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: run DB migrations from your machine (scripts/run-migration.sh)
# Project Settings → Database → Connection string → URI (include password)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@...

# --- Gmail API (Vercel serverless `/api/gmail/*`) — mirror Supabase keys for server-side code
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback

# Random secret for signing OAuth state (e.g. openssl rand -hex 32)
OAUTH_STATE_SECRET=

# Optional: explicit site origin for post-OAuth redirect (defaults from VERCEL_URL on Vercel)
# APP_ORIGIN=http://localhost:3000
