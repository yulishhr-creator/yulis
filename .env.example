# Copy to .env and fill from Supabase Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: run DB migrations from your machine (scripts/run-migration.sh)
# Project Settings → Database → Connection string → URI (include password)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@...

# --- Vercel serverless `/api/*` (not VITE_*) — same Supabase values for API auth
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Send email: Create a Make.com scenario (Webhooks "Custom webhook" → your email action),
# then paste the webhook URL here. Optional shared secret matches header X-Email-Webhook-Secret.
MAKE_EMAIL_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxx
# MAKE_EMAIL_WEBHOOK_SECRET=

# When using `npm run dev` or `npm run dev:stack` (Vite on :5173), `/api/*` is proxied here.
# DEV_API_PROXY_TARGET=http://localhost:3000
